            <column caption='NBA: Rebounds Per Game' datatype='real' name='[TRB 1]' role='measure' type='quantitative' />
            <column datatype='string' name='[Tm]' role='dimension' type='nominal' />
            <column caption='NBA: Value Over Replacement' datatype='real' name='[VORP]' role='measure' type='quantitative' />
            <column datatype='real' name='[WS]' role='measure' type='quantitative' />
            <column-instance column='[DraftYear]' derivation='Attribute' name='[attr:DraftYear:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Tm]' derivation='Attribute' name='[attr:Tm:nk]' pivot='key' type='nominal' />
