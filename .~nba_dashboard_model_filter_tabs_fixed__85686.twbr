      <aliases enabled='yes' />
      <column caption='NBA: Assists Per Game' datatype='real' name='[AST 1]' role='measure' type='quantitative' />
      <column caption='Selected Players Filter' datatype='boolean' name='[Calculation_1822520560463872]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[player] = [Parameters].[Parameter 1]&#10;OR [player] = [Parameters].[Parameter 2]' />
      </column>
      <column caption='Draft Pick Group' datatype='string' name='[Calculation_DraftPickGroup]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Pk] &lt;= 14 THEN &quot;Lottery&quot;&#10;ELSEIF [Pk] &lt;= 30 THEN &quot;Rest of 1st Round&quot;&#10;ELSE &quot;2nd Round&quot;&#10;END' />
      </column>
      <column caption='Draft Value Category' datatype='string' name='[Calculation_DraftValueLabel]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_DraftValueScore] &gt;= 5 THEN &quot;Steal&quot;&#10;ELSEIF [Calculation_DraftValueScore] &lt;= -5 THEN &quot;Bust&quot;&#10;ELSE &quot;Expected&quot;&#10;END' />
      </column>
      <column caption='Draft Value Score' datatype='real' name='[Calculation_DraftValueScore]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_NBAImpactScore] - [Calculation_ExpectedImpactByPick]' />
      </column>
      <column caption='Expected Impact By Draft Pick' datatype='real' name='[Calculation_ExpectedImpactByPick]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Pk] : AVG([Calculation_NBAImpactScore]) }' />
      </column>
      <column caption='Selected Model Result Filter' datatype='boolean' name='[Calculation_ModelResultSelected]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 5] = &quot;(All)&quot; OR [model_result] = [Parameters].[Parameter 5]' />
      </column>
      <column caption='NBA Impact Score' datatype='real' name='[Calculation_NBAImpactScore]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN([BPM]) * 2 + ZN([VORP]) * 0.5 + ZN([WS]) * 0.1' />
      </column>
      <column caption='Number of Players' datatype='integer' name='[Calculation_PlayerCount]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Player Tier' datatype='string' name='[Calculation_PlayerTier]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_NBAImpactScore] &gt;= 15 THEN &quot;Star&quot;&#10;ELSEIF [Calculation_NBAImpactScore] &gt;= 8 THEN &quot;Starter&quot;&#10;ELSEIF [Calculation_NBAImpactScore] &gt;= 3 THEN &quot;Rotation&quot;&#10;ELSEIF [Calculation_NBAImpactScore] &gt;= 0 THEN &quot;Bench/Fringe&quot;&#10;ELSE &quot;Low Impact&quot;&#10;END' />
      </column>
      <column caption='Selected Career Metric' datatype='real' name='[Calculation_SelectedGraphMeasure]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 4]&#10;WHEN &quot;NBA BPM&quot; THEN [BPM]&#10;WHEN &quot;VORP&quot; THEN [VORP]&#10;WHEN &quot;Win Shares&quot; THEN [WS]&#10;WHEN &quot;NBA PPG&quot; THEN [PTS 1]&#10;WHEN &quot;NBA RPG&quot; THEN [TRB 1]&#10;WHEN &quot;NBA APG&quot; THEN [AST 1]&#10;WHEN &quot;College BPM&quot; THEN [college_bpm]&#10;WHEN &quot;College PPG&quot; THEN [college_ppg]&#10;END' />
      </column>
      <column caption='Selected Draft Team Filter' datatype='boolean' name='[Calculation_TeamSelected]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3] = &quot;(All)&quot; OR [Tm] = [Parameters].[Parameter 3]' />
      </column>
