            </column>
            <column caption='Graph Measure' datatype='string' name='[Parameter 4]' param-domain-type='list' role='measure' type='nominal' value='&quot;NBA BPM&quot;'>
              <calculation class='tableau' formula='&quot;NBA BPM&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0sf5wsd0as0c3019b9fye0yvg5dk'>
