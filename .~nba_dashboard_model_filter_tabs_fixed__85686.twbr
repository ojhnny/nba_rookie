    <worksheet name='Draft Value: Steals vs Busts'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Draft Value: Steals vs Busts</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='tableau_nba_draft_master' name='federated.0sf5wsd0as0c3019b9fye0yvg5dk' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Draft Team' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATL&quot;'>
              <calculation class='tableau' formula='&quot;ATL&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0sf5wsd0as0c3019b9fye0yvg5dk'>
            <column datatype='real' name='[BPM]' role='measure' type='quantitative' />
            <column caption='Draft Value Category' datatype='string' name='[Calculation_DraftValueLabel]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_DraftValueScore] &gt;= 5 THEN &quot;Steal&quot;&#10;ELSEIF [Calculation_DraftValueScore] &lt;= -5 THEN &quot;Bust&quot;&#10;ELSE &quot;Expected&quot;&#10;END' />
            </column>
            <column caption='Draft Value Score' datatype='real' name='[Calculation_DraftValueScore]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_NBAImpactScore] - [Calculation_ExpectedImpactByPick]' />
            </column>
            <column caption='Expected Impact By Draft Pick' datatype='real' name='[Calculation_ExpectedImpactByPick]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Pk] : AVG([Calculation_NBAImpactScore]) }' />
            </column>
            <column caption='NBA Impact Score' datatype='real' name='[Calculation_NBAImpactScore]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN([BPM]) * 2 + ZN([VORP]) * 0.5 + ZN([WS]) * 0.1' />
            </column>
            <column caption='Selected Draft Team Filter' datatype='boolean' name='[Calculation_TeamSelected]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 3] = &quot;(All)&quot; OR [Tm] = [Parameters].[Parameter 3]' />
            </column>
            <column caption='Draft Year' datatype='integer' name='[DraftYear]' role='dimension' type='quantitative' />
            <column datatype='integer' name='[Pk]' role='measure' type='quantitative' />
            <column datatype='string' name='[Tm]' role='dimension' type='nominal' />
            <column caption='NBA: Value Over Replacement' datatype='real' name='[VORP]' role='measure' type='quantitative' />
            <column datatype='real' name='[WS]' role='measure' type='quantitative' />
            <column-instance column='[DraftYear]' derivation='Attribute' name='[attr:DraftYear:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Tm]' derivation='Attribute' name='[attr:Tm:nk]' pivot='key' type='nominal' />
            <column-instance column='[player]' derivation='Attribute' name='[attr:player:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_DraftValueScore]' derivation='Avg' name='[avg:Calculation_DraftValueScore:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_ExpectedImpactByPick]' derivation='Avg' name='[avg:Calculation_ExpectedImpactByPick:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_NBAImpactScore]' derivation='Avg' name='[avg:Calculation_NBAImpactScore:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Pk]' derivation='Avg' name='[avg:Pk:qk]' pivot='key' type='quantitative' />
            <column-instance column='[VORP]' derivation='Avg' name='[avg:VORP:qk]' pivot='key' type='quantitative' />
            <column-instance column='[WS]' derivation='Avg' name='[avg:WS:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_DraftValueLabel]' derivation='None' name='[none:Calculation_DraftValueLabel:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_TeamSelected]' derivation='None' name='[none:Calculation_TeamSelected:nk]' pivot='key' type='nominal' />
            <column-instance column='[player]' derivation='None' name='[none:player:nk]' pivot='key' type='nominal' />
            <column caption='Player' datatype='string' name='[player]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_DraftValueScore:qk]' included-values='non-null' />
          <filter class='categorical' column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_TeamSelected:nk]'>
            <groupfilter function='member' level='[none:Calculation_TeamSelected:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_TeamSelected:nk]</column>
            <column>[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_DraftValueScore:qk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <format attr='title' class='0' field='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Pk:qk]' scope='cols' value='Draft Pick' />
            <format attr='title' class='0' field='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_DraftValueScore:qk]' scope='rows' value='Value Above Expected Draft Pick' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
            <encodings>
              <color column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_DraftValueLabel:nk]' />
              <lod column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:player:nk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[attr:player:nk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[attr:Tm:nk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[attr:DraftYear:qk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_DraftValueScore:qk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_NBAImpactScore:qk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_ExpectedImpactByPick:qk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:VORP:qk]' />
              <tooltip column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:WS:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_DraftValueScore:qk]</rows>
