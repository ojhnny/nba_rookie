    <worksheet name='Draft Pick Group Impact'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Draft Pick Group Impact</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='tableau_nba_draft_master' name='federated.0sf5wsd0as0c3019b9fye0yvg5dk' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Draft Team' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATL&quot;'>
              <calculation class='tableau' formula='&quot;ATL&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0sf5wsd0as0c3019b9fye0yvg5dk'>
            <column datatype='real' name='[BPM]' role='measure' type='quantitative' />
            <column caption='Draft Pick Group' datatype='string' name='[Calculation_DraftPickGroup]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Pk] &lt;= 14 THEN &quot;Lottery&quot;&#10;ELSEIF [Pk] &lt;= 30 THEN &quot;Rest of 1st Round&quot;&#10;ELSE &quot;2nd Round&quot;&#10;END' />
            </column>
            <column caption='NBA Impact Score' datatype='real' name='[Calculation_NBAImpactScore]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN([BPM]) * 2 + ZN([VORP]) * 0.5 + ZN([WS]) * 0.1' />
            </column>
            <column caption='Selected Draft Team Filter' datatype='boolean' name='[Calculation_TeamSelected]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 3] = &quot;(All)&quot; OR [Tm] = [Parameters].[Parameter 3]' />
            </column>
            <column datatype='integer' name='[Pk]' role='measure' type='quantitative' />
            <column datatype='string' name='[Tm]' role='dimension' type='nominal' />
            <column caption='NBA: Value Over Replacement' datatype='real' name='[VORP]' role='measure' type='quantitative' />
            <column datatype='real' name='[WS]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_NBAImpactScore]' derivation='Avg' name='[avg:Calculation_NBAImpactScore:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_DraftPickGroup]' derivation='None' name='[none:Calculation_DraftPickGroup:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_TeamSelected]' derivation='None' name='[none:Calculation_TeamSelected:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_TeamSelected:nk]'>
            <groupfilter function='member' level='[none:Calculation_TeamSelected:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_TeamSelected:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <format attr='title' class='0' field='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_NBAImpactScore:qk]' scope='cols' value='Average NBA Impact Score' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_DraftPickGroup:nk]' />
              <text column='[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_NBAImpactScore:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[none:Calculation_DraftPickGroup:nk]</rows>
        <cols>[federated.0sf5wsd0as0c3019b9fye0yvg5dk].[avg:Calculation_NBAImpactScore:qk]</cols>
      </table>
      <simple-id uuid='{95FD2590-86A6-41A4-8833-006686C6C664}' />
